# InfluxDB Configuration
INFLUX_URL=http://localhost:8086
INFLUX_ORG=SHOESTRING
INFLUX_BUCKET=shoestring_data_bucket
INFLUX_READ_TOKEN=your_influx_token

# Kinabase Configuration
# KINABASE_API_BASE_URL is the *origin only* (no /api/v1). Kinabridge appends /api/v1 internally.
#
# LAN (Raspberry Pi on same network):
# KINABASE_API_BASE_URL=http://10.10.11.19:5272
#
# Public via ngrok:
KINABASE_API_BASE_URL=https://0458-46-17-166-115.ngrok-free.app

KINABASE_COLLECTION=584f2727-8b0b-4abd-8bad-e08d767e9527
KINABASE_DEVICES_COLLECTION=1abece96-c3b3-4423-ad58-346637a0ca02

# Auth (choose one option)
KINABASE_API_KEY=your_api_key
KINABASE_API_SECRET=your_api_secret
# KINABASE_JWT=your_manual_jwt_token

# Polling Configuration
POLL_INTERVAL_MS=120000

# Optional
# LOG_LEVEL=debug
# CONTROL_PORT=4300
# STATE_FILE=./last-run.json
